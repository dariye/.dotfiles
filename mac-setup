#!/bin/bash
# Optimized for Apple Silicon Mac (M-series)
# Based on Thoughtbot's laptop script and original setup

HOMEBREW_PREFIX="/opt/homebrew"
XDG_CONFIG_HOME="$HOME/.config"

set -euo pipefail
IFS=$'\n\t'

fancy_echo() {
  printf "\\n%b\\n" "$1"
}

if [ "$(uname -m)" != "arm64" ]; then
  fancy_echo "⚠️  This script is optimized for Apple Silicon (M-series) Macs"
  exit 1
fi

if [ "$(sw_vers -productVersion | cut -d. -f1)" -lt "14" ]; then
  fancy_echo "⚠️  This script requires macOS Sonoma (14.0) or later"
  exit 1
fi

mkdir -p "$XDG_CONFIG_HOME"

if ! command -v brew >/dev/null; then
  fancy_echo "🍺 Installing Homebrew..."
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

eval "$($HOMEBREW_PREFIX/bin/brew shellenv)"

if ! xcode-select -p &>/dev/null; then
  fancy_echo "Installing Xcode Command Line Tools..."
  xcode-select --install
  until xcode-select -p &>/dev/null; do
    sleep 5
  done
fi

fancy_echo "🍻 Installing Homebrew packages..."
brew bundle --file=./Brewfile --no-upgrade

fancy_echo "🐠 Setting up fish shell..."
if ! grep -q "$HOMEBREW_PREFIX/bin/fish" /etc/shells; then
  echo "$HOMEBREW_PREFIX/bin/fish" | sudo tee -a /etc/shells
fi
if [ "$SHELL" != "$HOMEBREW_PREFIX/bin/fish" ]; then
  chsh -s "$HOMEBREW_PREFIX/bin/fish"
fi

fancy_echo "📦 Installing language runtimes via mise..."
mise install --yes

# Gas Town (gt) — not available via Homebrew
fancy_echo "⛽ Installing Gas Town..."
if mise exec go -- go install github.com/steveyegge/gastown/cmd/gt@latest; then
  export PATH="$HOME/go/bin:$PATH"
  gt install --shell
else
  fancy_echo "⚠️  Gas Town installation failed (non-fatal, skipping)"
fi

fancy_echo "✅ Setup complete!"
